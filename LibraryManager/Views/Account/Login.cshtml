@model LibraryManager.DTOs.Account.LoginDto

@{
    ViewData["Title"] = "Log In";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4 shadow-sm p-4 bg-white rounded border">
        <h2 class="text-center mb-4">@ViewData["Title"]</h2>
        <hr />
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label font-weight-bold"></label>
                <input asp-for="Email" class="form-control" placeholder="Enter your email address..." />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label font-weight-bold"></label>
                <input asp-for="Password" class="form-control" placeholder="Enter your password..." />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                <label asp-for="RememberMe" class="form-check-label">Remember me</label>
            </div>

            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-primary btn-lg">Login</button>
            </div>
        </form>

        <div class="text-center mt-3">
            <span class="text-muted">Don't have an account?</span>
            <a asp-action="Register" class="text-decoration-none">Create one here</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}