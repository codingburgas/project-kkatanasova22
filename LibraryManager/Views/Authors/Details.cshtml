@model LibraryManager.DTOs.Author.AuthorDetailsDto

@{
    ViewData["Title"] = "Author Details";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white">
                <h4 class="mb-0">@Model.Name</h4>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted">System ID:</div>
                    <div class="col-sm-8"># @Model.Id</div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted">Created On:</div>
                    <div class="col-sm-8">@Model.CreatedAt.ToString("dd MMM yyyy")</div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted">Total Books:</div>
                    <div class="col-sm-8">
                        <span class="badge bg-primary fs-6">@Model.BooksCount</span>
                    </div>
                </div>
                <hr />
                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                    <a asp-controller="Books" asp-action="Index" asp-route-searchQuery="@Model.Name" class="btn btn-outline-primary">
                        View Author's Books
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>