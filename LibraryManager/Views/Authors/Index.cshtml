@model IEnumerable<LibraryManager.DTOs.Author.AuthorListDto>

@{
    ViewData["Title"] = "Authors Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-badge"></i> @ViewData["Title"]</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Author
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Author Name</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var author in Model)
                {
                    <tr>
                        <td class="align-middle ps-4">
                            <strong>@author.Name</strong>
                        </td>
                        <td class="text-end pe-4">
                            <a asp-action="Details" asp-route-id="@author.Id" class="btn btn-sm btn-outline-info">Details</a>
                            <form asp-action="Delete" asp-route-id="@author.Id" method="post" class="d-inline" 
                                  onsubmit="return confirm('Are you sure you want to delete this author?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>