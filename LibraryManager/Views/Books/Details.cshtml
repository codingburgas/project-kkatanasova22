@model LibraryManager.DTOs.Book.BookListDto

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Library</a></li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>

    <div class="card shadow-lg border-0 overflow-hidden">
        <div class="row g-0">
            <div class="col-md-4 bg-light d-flex align-items-center justify-content-center p-5">
                <i class="bi bi-book-half display-1 text-secondary"></i>
            </div>
            <div class="col-md-8">
                <div class="card-body p-4">
                    <h1 class="display-5 mb-0">@Model.Title</h1>
                    <p class="lead text-muted mb-4">by @Model.AuthorName</p>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <p class="mb-1 fw-bold text-uppercase small text-muted">Category</p>
                            <p class="fs-5">@Model.CategoryName</p>
                        </div>
                        <div class="col-sm-6">
                            <p class="mb-1 fw-bold text-uppercase small text-muted">ISBN</p>
                            <p class="fs-5">@Model.ISBN</p>
                        </div>
                        <div class="col-sm-6">
                            <p class="mb-1 fw-bold text-uppercase small text-muted">Availability</p>
                            @if (Model.IsAvailable)
                            {
                                <p class="fs-5 text-success"><i class="bi bi-check-circle-fill"></i> Available for Loan</p>
                            }
                            else
                            {
                                <p class="fs-5 text-danger"><i class="bi bi-x-circle-fill"></i> Currently Borrowed</p>
                            }
                        </div>
                        <div class="col-sm-6">
                            <p class="mb-1 fw-bold text-uppercase small text-muted">Location</p>
                            <p class="fs-5"><i class="bi bi-geo-alt"></i> @Model.Location</p>
                        </div>
                    </div>

                    <div class="mt-5 border-top pt-4">
                        <a asp-action="Index" class="btn btn-secondary">Back to Catalog</a>
                        @if (User.Identity.IsAuthenticated && Model.IsAvailable)
                        {
                            <form asp-controller="Loans" asp-action="Borrow" method="post" class="d-inline ms-2">
                                <input type="hidden" name="bookId" value="@Model.Id" />
                                <button type="submit" class="btn btn-primary px-4">Borrow this Book</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>