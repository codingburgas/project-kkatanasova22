@model IEnumerable<LibraryManager.DTOs.Loan.LoanListDto>

@{
    ViewData["Title"] = "All Active Loans";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-journal-check"></i> Active Loans Management</h2>
    <span class="badge bg-info text-dark">Total Active: @Model.Count()</span>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Book Title</th>
                    <th>Reader</th>
                    <th>Loan Date</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var loan in Model)
                {
                    <tr class="@(loan.IsOverdue ? "table-danger" : "")">
                        <td class="ps-4 fw-bold">@loan.BookTitle</td>
                        <td>@loan.ReaderName</td>
                        <td>@loan.LoanDate.ToString("dd MMM yyyy")</td>
                        <td>@loan.DueDate.ToString("dd MMM yyyy")</td>
                        <td>
                            @if (loan.IsOverdue)
                            {
                                <span class="badge bg-danger pulse-animation">OVERDUE</span>
                            }
                            else
                            {
                                <span class="badge bg-success">On Time</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <form asp-action="Return" asp-route(loanId)="@loan.Id" method="post">
                                <button type="submit" class="btn btn-sm btn-outline-primary"
                                        onclick="return confirm('Confirm book return?');">
                                    Mark Returned
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-emoji-smile fs-1 text-muted"></i>
        <p class="mt-2 text-muted">No active loans at the moment.</p>
    </div>
}