@model IEnumerable<LibraryManager.DTOs.Loan.LoanListDto>

@{
    ViewData["Title"] = "My Borrowed Books";
}

<h2 class="mb-4"><i class="bi bi-person-lines-fill"></i> @ViewData["Title"]</h2>

<div class="row g-4">
    @foreach (var loan in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm @(loan.IsReturned ? "opacity-75" : "border-primary")">
                <div class="card-body">
                    <h5 class="card-title">@loan.BookTitle</h5>
                    <hr />
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Borrowed:</span>
                        <span class="small">@loan.LoanDate.ToShortDateString()</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted small">Due Date:</span>
                        <span class="small fw-bold">@loan.DueDate.ToShortDateString()</span>
                    </div>

                    <div class="text-center">
                        @if (loan.IsReturned)
                        {
                            <span class="badge bg-secondary w-100 py-2">RETURNED</span>
                        }
                        else if (loan.IsOverdue)
                        {
                            <span class="badge bg-danger w-100 py-2">OVERDUE</span>
                        }
                        else
                        {
                            <span class="badge bg-primary w-100 py-2">ACTIVE</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-4">
        You haven't borrowed any books yet. <a asp-controller="Books" asp-action="Index">Browse the catalog!</a>
    </div>
}